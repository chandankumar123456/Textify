# Application
APP_NAME=Textify
DEBUG=false

# Database — SQLite by default (no setup needed)
# For PostgreSQL: postgresql://user:password@localhost:5432/textify
DATABASE_URL=sqlite:///./data/textify.db

# Local storage directory (relative to where backend is started)
DATA_DIR=data

# Upload limits
MAX_UPLOAD_SIZE_MB=50

# Allowed CORS origins for the frontend
CORS_ORIGINS=["http://localhost:3000"]

# Frontend API URL (used in frontend .env)
NEXT_PUBLIC_API_URL=http://localhost:8000
