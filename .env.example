# Database
DATABASE_URL=postgresql://textify:textify@localhost:5432/textify

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# S3-compatible storage (Supabase)
# Endpoint format: https://<project-ref>.supabase.co/storage/v1/s3
S3_ENDPOINT_URL=https://<project-ref>.supabase.co/storage/v1/s3
S3_ACCESS_KEY=<supabase-s3-access-key>
S3_SECRET_KEY=<supabase-s3-secret-key>
S3_BUCKET_NAME=<your-bucket-name>
S3_REGION=<your-supabase-region>

# App
DEBUG=true
MAX_UPLOAD_SIZE_MB=50
CORS_ORIGINS=["http://localhost:3000"]
